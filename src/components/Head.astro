---
import Default from '@astrojs/starlight/components/Head.astro';

// Starlight route data for the current page.
const { entry, id } = Astro.locals.starlightRoute;
const { title, description } = entry.data;

const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const mdMirrorPath = `/${id === '' || id === 'index' ? 'index' : id}.md`;

// Structured data: FAQPage for questions, TechArticle for architectures.
let jsonLd = null;
if (id.startsWith('questions/')) {
	jsonLd = {
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: [
			{
				'@type': 'Question',
				name: title,
				acceptedAnswer: { '@type': 'Answer', text: description ?? '' },
			},
		],
		url: pageUrl,
	};
} else if (id.startsWith('architectures/')) {
	jsonLd = {
		'@context': 'https://schema.org',
		'@type': 'TechArticle',
		headline: title,
		description: description ?? '',
		url: pageUrl,
	};
}
---

<Default><slot /></Default>
<link rel="alternate" type="text/markdown" href={mdMirrorPath} />
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

<script>
	// Client-side mermaid rendering for ```mermaid code fences. The mermaid
	// library (~large) is only fetched on pages that actually contain a diagram;
	// all other pages pay only for this detection script.
	const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
	if (blocks.length > 0) {
		const { default: mermaid } = await import('mermaid');
		const isDark = document.documentElement.dataset.theme === 'dark';
		mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'default' });
		let i = 0;
		for (const pre of blocks) {
			// innerText (not textContent): Expressive Code renders each line as a
			// block-level div, so textContent would lose the newlines.
			const code = (pre as HTMLElement).innerText ?? '';
			const container = pre.closest('.expressive-code') ?? pre;
			const target = document.createElement('div');
			try {
				const { svg } = await mermaid.render(`mermaid-${i++}`, code);
				target.innerHTML = svg;
				container.replaceWith(target);
			} catch {
				// Leave the code block visible if the diagram fails to render.
			}
		}
	}
</script>
